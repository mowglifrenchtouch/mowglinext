{
  "configById": {
    "3D!main": {
      "followTf": "base_link",
      "scene": {
        "labelScaleFactor": 1,
        "enableStats": false,
        "backgroundColor": "#1a1a2e",
        "transforms": {
          "axisScale": 0.3,
          "lineWidth": 0.01,
          "editable": false,
          "enablePreloading": false
        }
      },
      "cameraState": {
        "distance": 12,
        "perspective": true,
        "phi": 55,
        "target": [0, 0, 0],
        "targetOffset": [0, 0, 0],
        "targetOrientation": [0, 0, 0, 1],
        "thetaOffset": 45,
        "fovy": 45,
        "near": 0.01,
        "far": 500
      },
      "topics": {
        "/scan": {
          "visible": true,
          "pointSize": 3,
          "colorMode": "flat",
          "flatColor": "#ff3333",
          "decayTime": 0
        },
        "/map": {
          "visible": true,
          "alpha": 0.7,
          "unknownColor": "#1a1a2e"
        },
        "/local_costmap/costmap": {
          "visible": true,
          "alpha": 0.4
        },
        "/global_costmap/costmap": {
          "visible": false,
          "alpha": 0.3
        },
        "/robot_description": {
          "visible": true
        },
        "/coverage_planner_node/coverage_path": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.02
        },
        "/coverage_planner_node/coverage_outline": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.03
        },
        "/plan": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.03
        },
        "/local_plan": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.04
        },
        "/keepout_mask": {
          "visible": true,
          "alpha": 0.5,
          "unknownColor": "#00000000"
        },
        "/speed_mask": {
          "visible": false,
          "alpha": 0.3,
          "unknownColor": "#00000000"
        },
        "/wheel_odom": {
          "visible": false
        }
      },
      "publish": {
        "type": "pose_estimate",
        "poseTopic": "/initialpose",
        "pointTopic": "/clicked_point",
        "poseEstimateThetaDeviation": 0.26179939
      }
    },
    "CallService!start_mowing": {
      "serviceName": "/behavior_tree_node/high_level_control",
      "requestPayload": "{ \"command\": 1 }"
    },
    "CallService!return_home": {
      "serviceName": "/behavior_tree_node/high_level_control",
      "requestPayload": "{ \"command\": 2 }"
    },
    "CallService!stop": {
      "serviceName": "/behavior_tree_node/high_level_control",
      "requestPayload": "{ \"command\": 254 }"
    },
    "Publish!teleop": {
      "topicName": "/cmd_vel_teleop",
      "datatype": "geometry_msgs/msg/Twist",
      "value": "{ \"linear\": { \"x\": 0.0, \"y\": 0.0, \"z\": 0.0 }, \"angular\": { \"x\": 0.0, \"y\": 0.0, \"z\": 0.0 } }"
    },
    "RawMessages!status": {
      "topicPath": "/behavior_tree_node/high_level_status",
      "diffEnabled": false,
      "diffMethod": "custom",
      "diffTopicPath": "",
      "showFullMessageForDiff": false
    },
    "Plot!velocity": {
      "paths": [
        {
          "value": "/cmd_vel.linear.x",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "cmd_vel linear.x",
          "color": "#e74c3c",
          "showLine": true
        },
        {
          "value": "/cmd_vel.angular.z",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "cmd_vel angular.z",
          "color": "#3498db",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "Velocity Commands"
    },
    "Plot!battery": {
      "paths": [
        {
          "value": "/power.v_battery",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Battery (V)",
          "color": "#4e98e2",
          "showLine": true
        },
        {
          "value": "/power.v_charge",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Charger (V)",
          "color": "#2ecc71",
          "showLine": true
        },
        {
          "value": "/power.charge_current",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Charge Current (A)",
          "color": "#f39c12",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "sidebarDimension": 240,
      "title": "Power"
    },
    "StateTransitions!bt": {
      "paths": [
        {
          "value": "/behavior_tree_node/high_level_status.state",
          "label": "BT State",
          "timestampMethod": "receiveTime"
        }
      ]
    },
    "Log!rosout": {
      "searchTerms": [],
      "minLogLevel": 2,
      "nameFilter": {}
    },
    "Indicator!state": {
      "path": "/behavior_tree_node/high_level_status.state_name",
      "style": "background",
      "fallbackColor": "#555555",
      "fallbackLabel": "UNKNOWN",
      "rules": [
        {
          "operator": "=",
          "rawValue": "IDLE",
          "color": "#3498db",
          "label": "IDLE"
        },
        {
          "operator": "=",
          "rawValue": "AUTONOMOUS",
          "color": "#2ecc71",
          "label": "MOWING"
        },
        {
          "operator": "=",
          "rawValue": "RECORDING",
          "color": "#f39c12",
          "label": "RECORDING"
        }
      ]
    },
    "Indicator!emergency": {
      "path": "/behavior_tree_node/high_level_status.emergency",
      "style": "background",
      "fallbackColor": "#2ecc71",
      "fallbackLabel": "OK",
      "rules": [
        {
          "operator": "=",
          "rawValue": "true",
          "color": "#e74c3c",
          "label": "EMERGENCY"
        }
      ]
    },
    "RawMessages!diagnostics": {
      "topicPath": "/diagnostics",
      "diffEnabled": false,
      "diffMethod": "custom",
      "diffTopicPath": "",
      "showFullMessageForDiff": false
    },
    "Plot!gps_precision": {
      "paths": [
        {
          "value": "/precision/gps_error_m.data",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "GPS Error (m)",
          "color": "#e74c3c",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "GPS Precision",
      "yAxisMin": 0
    },
    "Plot!wheel_odom": {
      "paths": [
        {
          "value": "/precision/wheel_odom_speed.data",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Wheel Speed (m/s)",
          "color": "#2ecc71",
          "showLine": true
        },
        {
          "value": "/cmd_vel.linear.x",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Cmd Vel (m/s)",
          "color": "#3498db",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "Wheel Odometry vs Commanded",
      "yAxisMin": -0.1
    },
    "Plot!lidar_precision": {
      "paths": [
        {
          "value": "/precision/lidar_min_range.data",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Min Range (m)",
          "color": "#e67e22",
          "showLine": true
        },
        {
          "value": "/precision/lidar_scan_count.data",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Valid Points",
          "color": "#9b59b6",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "LiDAR Precision",
      "yAxisMin": 0
    },
    "Plot!overall_quality": {
      "paths": [
        {
          "value": "/precision/localization_quality.data",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Quality Score (0-100)",
          "color": "#1abc9c",
          "showLine": true
        },
        {
          "value": "/precision/slam_map_known_pct.data",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "SLAM Map Known %",
          "color": "#f1c40f",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "Overall Localization Quality",
      "yAxisMin": 0,
      "yAxisMax": 100
    }
  },
  "globalVariables": {},
  "layout": {
    "first": {
      "first": "3D!main",
      "second": {
        "first": {
          "first": {
            "first": "Indicator!state",
            "second": "Indicator!emergency",
            "direction": "row",
            "splitPercentage": 60
          },
          "second": {
            "first": "CallService!start_mowing",
            "second": {
              "first": "CallService!return_home",
              "second": "CallService!stop",
              "direction": "column",
              "splitPercentage": 50
            },
            "direction": "column",
            "splitPercentage": 33
          },
          "direction": "column",
          "splitPercentage": 15
        },
        "second": {
          "first": "Publish!teleop",
          "second": {
            "first": "RawMessages!status",
            "second": "StateTransitions!bt",
            "direction": "column",
            "splitPercentage": 50
          },
          "direction": "column",
          "splitPercentage": 30
        },
        "direction": "column",
        "splitPercentage": 45
      },
      "direction": "row",
      "splitPercentage": 75
    },
    "second": {
      "first": {
        "first": {
          "first": "Plot!velocity",
          "second": "Plot!battery",
          "direction": "row",
          "splitPercentage": 50
        },
        "second": {
          "first": "Plot!gps_precision",
          "second": "Plot!wheel_odom",
          "direction": "row",
          "splitPercentage": 50
        },
        "direction": "column",
        "splitPercentage": 50
      },
      "second": {
        "first": {
          "first": "Plot!lidar_precision",
          "second": "Plot!overall_quality",
          "direction": "row",
          "splitPercentage": 50
        },
        "second": {
          "first": "Log!rosout",
          "second": "RawMessages!diagnostics",
          "direction": "row",
          "splitPercentage": 60
        },
        "direction": "column",
        "splitPercentage": 50
      },
      "direction": "column",
      "splitPercentage": 50
    },
    "direction": "column",
    "splitPercentage": 55
  },
  "playbackConfig": {
    "speed": 1
  },
  "userNodes": {},
