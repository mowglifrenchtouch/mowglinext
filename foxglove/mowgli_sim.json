{
  "configById": {
    "3D!main": {
      "followTf": "base_link",
      "scene": {
        "labelScaleFactor": 1,
        "enableStats": false,
        "backgroundColor": "#1a1a2e",
        "transforms": {
          "axisScale": 0.3,
          "lineWidth": 0.01,
          "editable": false,
          "enablePreloading": false
        }
      },
      "cameraState": {
        "distance": 12,
        "perspective": true,
        "phi": 55,
        "target": [0, 0, 0],
        "targetOffset": [0, 0, 0],
        "targetOrientation": [0, 0, 0, 1],
        "thetaOffset": 45,
        "fovy": 45,
        "near": 0.01,
        "far": 500
      },
      "topics": {
        "/scan": {
          "visible": true,
          "pointSize": 3,
          "colorMode": "flat",
          "flatColor": "#ff3333",
          "decayTime": 0
        },
        "/map": {
          "visible": true,
          "alpha": 0.7,
          "unknownColor": "#1a1a2e"
        },
        "/local_costmap/costmap": {
          "visible": true,
          "alpha": 0.4
        },
        "/global_costmap/costmap": {
          "visible": false,
          "alpha": 0.3
        },
        "/robot_description": {
          "visible": true
        },
        "/coverage_planner_node/coverage_path": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.02
        },
        "/coverage_planner_node/coverage_outline": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.03
        },
        "/plan": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.03
        },
        "/local_plan": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.04
        }
      },
      "publish": {
        "type": "pose_estimate",
        "poseTopic": "/initialpose",
        "pointTopic": "/clicked_point",
        "poseEstimateThetaDeviation": 0.26179939
      }
    },
    "CallService!start_mowing": {
      "serviceName": "/behavior_tree_node/high_level_control",
      "requestPayload": "{ \"command\": 1 }"
    },
    "CallService!return_home": {
      "serviceName": "/behavior_tree_node/high_level_control",
      "requestPayload": "{ \"command\": 2 }"
    },
    "CallService!stop": {
      "serviceName": "/behavior_tree_node/high_level_control",
      "requestPayload": "{ \"command\": 254 }"
    },
    "Publish!teleop": {
      "topicName": "/cmd_vel_teleop",
      "datatype": "geometry_msgs/msg/Twist",
      "value": "{ \"linear\": { \"x\": 0.0, \"y\": 0.0, \"z\": 0.0 }, \"angular\": { \"x\": 0.0, \"y\": 0.0, \"z\": 0.0 } }"
    },
    "RawMessages!status": {
      "topicPath": "/behavior_tree_node/high_level_status",
      "diffEnabled": false,
      "diffMethod": "custom",
      "diffTopicPath": "",
      "showFullMessageForDiff": false
    },
    "Plot!velocity": {
      "paths": [
        {
          "value": "/cmd_vel.linear.x",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "cmd_vel linear.x",
          "color": "#e74c3c",
          "showLine": true
        },
        {
          "value": "/cmd_vel.angular.z",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "cmd_vel angular.z",
          "color": "#3498db",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "Velocity Commands"
    },
    "Plot!battery": {
      "paths": [
        {
          "value": "/hardware_bridge/power.v_battery",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Battery (V)",
          "color": "#4e98e2",
          "showLine": true
        },
        {
          "value": "/hardware_bridge/power.v_charge",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Charger (V)",
          "color": "#2ecc71",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "sidebarDimension": 240,
      "title": "Power"
    },
    "StateTransitions!bt": {
      "paths": [
        {
          "value": "/behavior_tree_node/high_level_status.state",
          "label": "BT State",
          "timestampMethod": "receiveTime"
        }
      ]
    },
    "Log!rosout": {
      "searchTerms": [],
      "minLogLevel": 2,
      "nameFilter": {}
    }
  },
  "globalVariables": {},
  "layout": {
    "first": {
      "first": "3D!main",
      "second": {
        "first": {
          "first": "CallService!start_mowing",
          "second": {
            "first": "CallService!return_home",
            "second": "CallService!stop",
            "direction": "column",
            "splitPercentage": 50
          },
          "direction": "column",
          "splitPercentage": 33
        },
        "second": {
          "first": "Publish!teleop",
          "second": {
            "first": "RawMessages!status",
            "second": "StateTransitions!bt",
            "direction": "column",
            "splitPercentage": 50
          },
          "direction": "column",
          "splitPercentage": 30
        },
        "direction": "column",
        "splitPercentage": 40
      },
      "direction": "row",
      "splitPercentage": 75
    },
    "second": {
      "first": {
        "first": "Plot!velocity",
        "second": "Plot!battery",
        "direction": "row",
        "splitPercentage": 50
      },
      "second": "Log!rosout",
      "direction": "column",
      "splitPercentage": 55
    },
    "direction": "column",
    "splitPercentage": 65
  },
  "playbackConfig": {
    "speed": 1
  },
  "userNodes": {},
  "version": 1
}
