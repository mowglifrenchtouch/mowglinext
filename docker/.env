# ROS2 Domain ID — all containers must share the same value for DDS discovery
ROS_DOMAIN_ID=0

# IP of the mower Pi (used in ser2net mode for socat serial relays)
MOWER_IP=10.69.4.198

# LiDAR serial port and baud rate (LD19 on hardware UART)
LIDAR_PORT=/dev/ttyS1
LIDAR_BAUD=230400

# Mowgli ROS2 image (built from mowgli_ros2/Dockerfile)
MOWGLI_ROS2_IMAGE=ghcr.io/cedbossneo/mowgli-ros2/mowgli-ros2:main

# GPS image (built from gps/Dockerfile)
GPS_IMAGE=ghcr.io/cedbossneo/mowgli-docker/gps:v3

# LiDAR image (built from lidar/Dockerfile)
LIDAR_IMAGE=ghcr.io/cedbossneo/mowgli-docker/lidar:v3

# OpenMower GUI image (built from openmower-gui/Dockerfile)
GUI_IMAGE=ghcr.io/cedbossneo/openmower-gui:v3
