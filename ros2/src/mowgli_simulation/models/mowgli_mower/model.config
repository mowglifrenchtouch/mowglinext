<?xml version="1.0"?>
<model>
  <name>Mowgli Mower</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>

  <author>
    <name>Cedric</name>
    <email>cedric@example.com</email>
  </author>

  <description>
    Standalone Gazebo Ignition model of the Mowgli autonomous robot mower.
    Based on YardForce Classic 500 approximate dimensions.

    Sensors:
      - Differential drive (gz-sim-diff-drive-system)
      - 360-degree 2-D LiDAR, 720 samples, 10 Hz (/scan)
      - IMU at 100 Hz (/imu/data_raw)
      - NavSat / GPS at 5 Hz (/gps/fix)

    Dimensions:
      Body:   0.55 x 0.40 x 0.15 m
      Wheels: r=0.10 m, w=0.05 m, track 0.35 m
      Caster: r=0.05 m (front)
  </description>
</model>
