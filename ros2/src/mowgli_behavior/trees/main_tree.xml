<?xml version="1.0" encoding="UTF-8"?>
<!--
  main_tree.xml — Mowgli BehaviorTree.CPP v4 main tree

  State constants (HighLevelStatus.msg):
    HIGH_LEVEL_STATE_NULL           = 0
    HIGH_LEVEL_STATE_IDLE           = 1
    HIGH_LEVEL_STATE_AUTONOMOUS     = 2
    HIGH_LEVEL_STATE_RECORDING      = 3
    HIGH_LEVEL_STATE_MANUAL_MOWING  = 4

  HighLevelControl commands (HighLevelControl.srv):
    COMMAND_START      = 1
    COMMAND_HOME       = 2
    COMMAND_S1         = 3   (recording)
    COMMAND_S2         = 4   (mow next area)
    COMMAND_MANUAL_MOW = 7
-->
<root BTCPP_format="4" main_tree_to_execute="MowgliMain">

  <BehaviorTree ID="MowgliMain">
    <ReactiveSequence name="Root">

      <!-- ================================================================
           GUARD 1: Emergency (always checked, highest priority)
           Polls every 1s. If the robot is placed back on the dock
           (charging detected), automatically send an emergency release
           to the firmware. The firmware is the safety authority and
           will only clear the latch if the physical trigger (lift/stop
           button) is no longer asserted.
           ================================================================ -->
      <Fallback name="EmergencyGuard">
        <Inverter><IsEmergency/></Inverter>
        <Sequence name="EmergencyHandler">
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="0" state_name="EMERGENCY"/>
          <Fallback name="AutoResetOrWait">
            <!-- If charging (on dock), auto-reset emergency -->
            <Sequence name="DockAutoReset">
              <IsCharging/>
              <ResetEmergency/>
              <WaitForDuration duration_sec="1.0"/>
            </Sequence>
            <!-- Not on dock — just wait and re-check -->
            <WaitForDuration duration_sec="1.0"/>
          </Fallback>
        </Sequence>
      </Fallback>

      <!-- ================================================================
           GUARD 2: Two-tier boundary violation
             * Lethal violation (outside area by more than
               lethal_boundary_margin_m, default 0.5m in map_server_node):
               blade + motors operating this far outside the authorised
               zone can cause real damage — emergency stop, wait for
               operator. No automatic recovery.
             * Soft violation (outside area but within the margin):
               attempt to navigate back to the known-inside dock pose.
               If Nav2 can route us back, normal mowing resumes. If it
               can't inside two attempts, escalate to the lethal path.
           The old behaviour was "BackUp 1m up to 5 times", which pushed
           the robot FURTHER along whatever direction it just crossed
           into — today's run ended with the robot ~50 cm past the
           east edge of the polygon, and each recovery BackUp drove it
           another 30 cm in the same wrong direction.
           ================================================================ -->
      <Fallback name="BoundaryGuard">
        <Inverter><IsBoundaryViolation/></Inverter>

        <!-- Lethal path: stop immediately, latch -->
        <Sequence name="LethalBoundaryHandler">
          <IsLethalBoundaryViolation/>
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="0" state_name="BOUNDARY_EMERGENCY_STOP"/>
          <!-- Hold here forever — operator intervention required. A long
               wait prevents the tree from re-ticking and potentially
               re-issuing goals; the emergency status is visible in the
               GUI so the user knows to recover manually. -->
          <WaitForDuration duration_sec="3600.0"/>
        </Sequence>

        <!-- Soft path: stop, then route back to a known-inside pose -->
        <Sequence name="SoftBoundaryHandler">
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="2" state_name="BOUNDARY_RECOVERY"/>
          <Fallback name="RecoverOrEscalate">
            <!-- Navigate back to the dock (guaranteed inside the area
                 if operator configured dock_pose correctly). Two tries
                 before escalating to lethal behaviour. -->
            <RetryUntilSuccessful num_attempts="2" name="RecoveryRetry">
              <Sequence name="NavigateBackInside">
                <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                <!-- Succeed only if the DockRobot action actually put us
                     back inside a defined area. -->
                <Inverter><IsBoundaryViolation/></Inverter>
              </Sequence>
            </RetryUntilSuccessful>
            <!-- Recovery failed — treat as lethal going forward. -->
            <Sequence name="EscalateToEmergency">
              <SetMowerEnabled enabled="false"/>
              <StopMoving/>
              <PublishHighLevelStatus state="0" state_name="BOUNDARY_EMERGENCY_STOP"/>
              <WaitForDuration duration_sec="3600.0"/>
            </Sequence>
          </Fallback>
        </Sequence>
      </Fallback>

      <!-- ================================================================
           GUARD 3: GPS quality adaptation (reactive)
           ================================================================ -->
      <Fallback name="GPSModeSelector">
        <Sequence name="PreciseMode">
          <IsGPSFixed/>
          <SetNavMode mode="precise"/>
        </Sequence>
        <SetNavMode mode="degraded"/>
      </Fallback>

      <!-- ================================================================
           MAIN LOGIC
           Priority: critical battery → mow → home → record → idle
           ================================================================ -->
      <Fallback name="MainLogic">

        <!-- ============================================================
             a. Critical battery — emergency dock, clear command
             Navigation failure is non-fatal (stay where we are).
             ============================================================ -->
        <Sequence name="CriticalBatteryDock">
          <IsBatteryLow threshold="10.0"/>
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="1" state_name="CRITICAL_BATTERY_DOCKING"/>
          <SaveObstacles/>
          <SaveSlamMap map_path="/ros2_ws/maps/garden_map"/>
          <Fallback name="CriticalNavOrStop">
            <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
            <!-- Docking failed — stay stopped, battery is critical -->
            <Sequence>
              <PublishHighLevelStatus state="0" state_name="CRITICAL_BATTERY_NAV_FAILED"/>
              <AlwaysSuccess/>
            </Sequence>
          </Fallback>
          <PublishHighLevelStatus state="1" state_name="IDLE_DOCKED"/>
          <ClearCommand/>
        </Sequence>

        <!-- ============================================================
             b. Mowing (COMMAND_START = 1)
             ============================================================ -->
        <Sequence name="MowingSequence">
          <IsCommand command="1"/>

          <!-- Wait for Nav2 to be fully active. Polled check: finishes in
               ~50 ms once the four lifecycle_manager_navigation nodes
               (bt_navigator / controller / planner / behavior) are all
               active; retries once per second for up to 60 s on ARM cold
               boot. Previously this was a hardcoded 30 s sleep inside the
               on-dock path only — which (a) wasted time when Nav2 was
               already ready, and (b) let the off-dock path issue goals
               into a half-up Nav2 stack, observed as bt_navigator stuck
               inactive → instant NavigateToPose rejections → skip-cascade
               drives the robot right out of the mowing area. -->
          <PublishHighLevelStatus state="2" state_name="PREFLIGHT_CHECK"/>
          <Fallback name="Nav2ReadyOrProceed">
            <RetryUntilSuccessful num_attempts="60" name="Nav2ReadyPoll">
              <Fallback>
                <Nav2Active timeout_sec="0.5"/>
                <Sequence>
                  <WaitForDuration duration_sec="1.0"/>
                  <AlwaysFailure/>
                </Sequence>
              </Fallback>
            </RetryUntilSuccessful>
            <!-- Timeout: proceed anyway with a warning. BoundaryGuard and
                 the emergency latch still apply; we'd rather let the run
                 fail fast at the first goal than freeze before starting. -->
            <AlwaysSuccess/>
          </Fallback>

          <!-- Undock: only if currently charging (on dock).
               If already undocked, skip entirely. -->
          <PublishHighLevelStatus state="2" state_name="UNDOCKING"/>
          <WaitForDuration duration_sec="1.0"/>
          <Fallback name="UndockOrSkip">
            <!-- Already undocked? Skip. -->
            <Inverter><IsCharging/></Inverter>
            <!-- On dock — wait for GPS, save map, then undock -->
            <Sequence name="UndockSequence">
              <!-- Comprehensive readiness gate before undocking: verifies
                   GPS fix type, battery, TF chain, mowing area, coverage
                   service — all in a single node with a clear failure log.
                   Retry for up to 30s to allow transient issues (GPS not
                   yet RTK, late-starting nodes) to resolve, then proceed
                   anyway to not block indefinitely at low-GPS sites. -->
              <PublishHighLevelStatus state="2" state_name="PREFLIGHT_CHECK"/>
              <Fallback name="PreFlightOrTimeout">
                <RetryUntilSuccessful num_attempts="30">
                  <Fallback>
                    <PreFlightCheck min_battery="20.0" min_gps_fix_type="2" tf_timeout_sec="0.5"/>
                    <Sequence>
                      <WaitForDuration duration_sec="1.0"/>
                      <AlwaysFailure/>
                    </Sequence>
                  </Fallback>
                </RetryUntilSuccessful>
                <!-- Timeout: proceed with a warning in logs -->
                <AlwaysSuccess/>
              </Fallback>
              <!-- Save SLAM map while docked with correct heading.
                   If undock flips heading, restart loads this good map. -->
              <SaveSlamMap map_path="/ros2_ws/maps/garden_map"/>
              <PublishHighLevelStatus state="2" state_name="UNDOCKING"/>
              <RecordUndockStart/>
              <!-- Nav2 readiness is already guaranteed by the Nav2Active
                   poll above UndockOrSkip; the old hardcoded 30 s sleep
                   here is no longer needed. -->
              <ClearCostmap/>
              <!-- BackUp instead of UndockRobot: opennav_docking isDocked()
                   uses geometric distance to dock pose which fails with
                   SLAM relocalization drift. BackUp reliably reverses
                   off the dock via Nav2 behavior_server.
                   Distance trimmed from 2.0m to 1.0m after an observed
                   boundary-violation: 2m put the robot ~0.3m past the
                   east edge of a tight garden polygon. 1m gives the F9P
                   enough displacement to calibrate undock heading while
                   staying safely inside typical boundaries. -->
              <BackUp backup_dist="1.0" backup_speed="0.20"/>
              <!-- Wait for RTK Fixed after undock. The dock often has a
                   metal canopy that attenuates GPS; once the robot is 2 m
                   out the F9P should re-acquire quickly. Timeout proceeds
                   anyway at degraded precision rather than freeze. -->
              <WaitForGpsFix timeout_sec="20.0" min_fix_type="4"/>
              <!-- Compute heading from GPS displacement during undock -->
              <CalibrateHeadingFromUndock/>
              <!-- Clear costmaps again after undock — dock structure must be
                   cleared before navigation starts. -->
              <ClearCostmap/>
            </Sequence>
            <!-- Undock failed — abort -->
            <Sequence name="UndockFailed">
              <StopMoving/>
              <PublishHighLevelStatus state="1" state_name="UNDOCK_FAILED"/>
              <ClearCommand/>
              <AlwaysFailure/>
            </Sequence>
          </Fallback>

          <!-- Record if it was raining at start — user chose to mow in rain -->
          <WasRainingAtStart/>

          <!-- Wait for obstacle detection before starting -->
          <WaitForDuration duration_sec="3.0"/>

          <!-- ════════════════════════════════════════════════════════
               CELL-BASED STRIP COVERAGE
               Each iteration: get next strip → transit → mow strip.
               No full-path pre-planning. Obstacles handled dynamically
               by Nav2 costmap. Progress tracked in mow_progress grid.
               ════════════════════════════════════════════════════════ -->
          <PublishHighLevelStatus state="2" state_name="MOWING"/>

          <ReactiveSequence name="MowingCommandGuard">
          <IsCommand command="1"/>

          <Fallback name="StripCoverageWithRecovery">

            <ReactiveSequence name="StripGuards">

              <!-- Reactive rain check -->
              <Fallback name="RainGuard">
                <Inverter><IsNewRain/></Inverter>
                <Sequence name="RainDockAndResume">
                  <SetMowerEnabled enabled="false"/>
                  <StopMoving/>
                  <PublishHighLevelStatus state="1" state_name="RAIN_DETECTED_DOCKING"/>
                  <SaveSlamMap map_path="/ros2_ws/maps/garden_map"/>
                  <Fallback name="RainNavOrStay">
                    <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                    <AlwaysSuccess/>
                  </Fallback>
                  <PublishHighLevelStatus state="1" state_name="RAIN_WAITING"/>
                  <Fallback name="RainWaitOrTimeout">
                    <RetryUntilSuccessful num_attempts="1440">
                      <Fallback>
                        <Inverter><IsRainDetected/></Inverter>
                        <Sequence>
                          <WaitForDuration duration_sec="30.0"/>
                          <AlwaysFailure/>
                        </Sequence>
                      </Fallback>
                    </RetryUntilSuccessful>
                    <Sequence name="RainTimeout">
                      <PublishHighLevelStatus state="1" state_name="RAIN_TIMEOUT"/>
                      <ClearCommand/>
                      <AlwaysFailure/>
                    </Sequence>
                  </Fallback>
                  <IsResumeUndockAllowed max_attempts="3"/>
                  <PublishHighLevelStatus state="2" state_name="RESUMING_AFTER_RAIN"/>
                  <WaitForDuration duration_sec="1.0"/>
                  <Fallback name="RainResumeUndock">
                    <!-- BackUp instead of UndockRobot: opennav_docking isDocked()
                   uses geometric distance to dock pose which fails with
                   SLAM relocalization drift. BackUp reliably reverses
                   off the dock via Nav2 behavior_server. -->
              <BackUp backup_dist="1.5" backup_speed="0.20"/>
                    <Sequence>
                      <RecordResumeUndockFailure/>
                      <ClearCommand/>
                      <AlwaysFailure/>
                    </Sequence>
                  </Fallback>
                  <PublishHighLevelStatus state="2" state_name="MOWING"/>
                </Sequence>
              </Fallback>

              <!-- Reactive battery check -->
              <Fallback name="BatteryGuard">
                <Inverter><NeedsDocking threshold="20.0"/></Inverter>
                <Sequence name="BatteryDockAndResume">
                  <SetMowerEnabled enabled="false"/>
                  <StopMoving/>
                  <PublishHighLevelStatus state="1" state_name="LOW_BATTERY_DOCKING"/>
                  <SaveSlamMap map_path="/ros2_ws/maps/garden_map"/>
                  <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                  <PublishHighLevelStatus state="1" state_name="CHARGING"/>
                  <Fallback name="ChargeOrAbort">
                    <RetryUntilSuccessful num_attempts="960">
                      <Sequence>
                        <IsChargingProgressing/>
                        <Fallback>
                          <IsBatteryAbove threshold="95.0"/>
                          <Sequence>
                            <WaitForDuration duration_sec="30.0"/>
                            <AlwaysFailure/>
                          </Sequence>
                        </Fallback>
                      </Sequence>
                    </RetryUntilSuccessful>
                    <Sequence name="ChargerFailed">
                      <PublishHighLevelStatus state="1" state_name="CHARGER_FAILED"/>
                      <ClearCommand/>
                      <AlwaysFailure/>
                    </Sequence>
                  </Fallback>
                  <IsResumeUndockAllowed max_attempts="3"/>
                  <PublishHighLevelStatus state="2" state_name="RESUMING_UNDOCKING"/>
                  <WaitForDuration duration_sec="1.0"/>
                  <Fallback name="ResumeUndockOrAbort">
                    <!-- BackUp instead of UndockRobot: opennav_docking isDocked()
                   uses geometric distance to dock pose which fails with
                   SLAM relocalization drift. BackUp reliably reverses
                   off the dock via Nav2 behavior_server. -->
              <BackUp backup_dist="1.5" backup_speed="0.20"/>
                    <Sequence>
                      <RecordResumeUndockFailure/>
                      <ClearCommand/>
                      <AlwaysFailure/>
                    </Sequence>
                  </Fallback>
                  <PublishHighLevelStatus state="2" state_name="MOWING"/>
                </Sequence>
              </Fallback>

              <!-- Multi-area coverage loop.
                   Outer loop: iterate through all mowing areas.
                   Inner loop: mow all strips in the current area.
                   GetNextUnmowedArea returns FAILURE when all areas are done.
                   GetNextStrip returns FAILURE when current area is done → next area. -->
              <Repeat num_cycles="100" name="AreaLoop">
                <Sequence name="MowOneArea">
                  <GetNextUnmowedArea area_index="{current_area_index}"/>
                  <Repeat num_cycles="500" name="StripLoop">
                    <Sequence name="GetAndMowStrip">
                      <GetNextStrip area_index="{current_area_index}"/>
                      <Fallback name="MowOrSkip">
                        <!-- Try up to 3 times to reach and mow this strip -->
                        <RetryUntilSuccessful num_attempts="3" name="StripRetry">
                          <Sequence name="MowOneStrip">
                            <PublishHighLevelStatus state="2" state_name="TRANSIT"/>
                            <TransitToStrip/>
                            <PublishHighLevelStatus state="2" state_name="MOWING"/>
                            <FollowStrip/>
                          </Sequence>
                        </RetryUntilSuccessful>
                        <!-- All 3 attempts failed — skip this strip, increment counter -->
                        <Sequence name="SkipStrip">
                          <PublishHighLevelStatus state="2" state_name="SKIP_STRIP"/>
                          <SetMowerEnabled enabled="false"/>
                          <StopMoving/>
                          <Fallback>
                            <BackUp backup_dist="0.3" backup_speed="0.2"/>
                            <AlwaysSuccess/>
                          </Fallback>
                          <ClearCostmap/>
                          <IncrementSkippedSwaths/>
                          <WaitForDuration duration_sec="2.0"/>
                          <PublishHighLevelStatus state="2" state_name="MOWING"/>
                        </Sequence>
                      </Fallback>
                    </Sequence>
                  </Repeat>
                </Sequence>
              </Repeat>

            </ReactiveSequence>

            <!-- Coverage failed — dock gracefully -->
            <Sequence name="FailedCoverageDock">
              <SetMowerEnabled enabled="false"/>
              <SaveSlamMap map_path="/ros2_ws/maps/garden_map"/>
              <PublishHighLevelStatus state="1" state_name="COVERAGE_FAILED_DOCKING"/>
              <Fallback name="FailedCoverageNavOrStop">
                <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                <Sequence>
                  <PublishHighLevelStatus state="0" state_name="NAV_TO_DOCK_FAILED"/>
                  <AlwaysSuccess/>
                </Sequence>
              </Fallback>
              <PublishHighLevelStatus state="1" state_name="IDLE_DOCKED"/>
              <ClearCommand/>
            </Sequence>
          </Fallback>
          </ReactiveSequence>

          <!-- Mowing complete — dock -->
          <SetMowerEnabled enabled="false"/>
          <PublishHighLevelStatus state="1" state_name="MOWING_COMPLETE"/>
          <SaveObstacles/>
          <SaveSlamMap map_path="/ros2_ws/maps/garden_map"/>
          <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
          <PublishHighLevelStatus state="1" state_name="IDLE_DOCKED"/>
          <ClearCommand/>
        </Sequence>

        <!-- ============================================================
             c. Home (COMMAND_HOME = 2)
             Wrapped in a ReactiveSequence with IsCommand(2) at the top:
             if the user sends any other command (including 0 / cancel)
             while DockRobot is mid-flight, the guard returns FAILURE and
             the running action is halted via onHalted() — so the BT does
             not hold the user hostage for up to ~5 min of dock retries.
             The inner <Sequence> keeps memory semantics so StopMoving and
             the other one-shot setup steps don't re-fire each tick.
             ============================================================ -->
        <ReactiveSequence name="HomeSequence">
          <IsCommand command="2"/>
          <Sequence name="HomeAction">
            <SetMowerEnabled enabled="false"/>
            <StopMoving/>
            <Fallback name="HomeOrAlreadyDocked">
              <!-- Already on dock and charging? Skip navigation. -->
              <IsCharging/>
              <Sequence name="NavigateHome">
                <PublishHighLevelStatus state="1" state_name="RETURNING_HOME"/>
                <SaveObstacles/>
                <SaveSlamMap map_path="/ros2_ws/maps/garden_map"/>
                <Fallback name="HomeNavOrStop">
                  <DockRobot dock_id="home_dock" dock_type="simple_charging_dock"/>
                  <Sequence>
                    <PublishHighLevelStatus state="0" state_name="NAV_TO_DOCK_FAILED"/>
                    <AlwaysSuccess/>
                  </Sequence>
                </Fallback>
              </Sequence>
            </Fallback>
            <PublishHighLevelStatus state="1" state_name="IDLE_DOCKED"/>
            <ClearCommand/>
          </Sequence>
        </ReactiveSequence>

        <!-- ============================================================
             d. Recording (COMMAND_S1 = 3 = COMMAND_RECORD_AREA)
             User drives robot along boundary. The RecordArea node
             records positions at 2 Hz and publishes a live trajectory
             preview. When the user presses "Finish" (command 5) the
             trajectory is simplified with Douglas-Peucker and saved
             as a mowing area. "Cancel" (command 6) discards it.
             ============================================================ -->
        <Sequence name="RecordingSequence">
          <IsCommand command="3"/>
          <PublishHighLevelStatus state="3" state_name="RECORDING"/>
          <RecordArea
            simplification_tolerance="0.2"
            min_vertices="3"
            min_area="1.0"
            record_rate_hz="2.0"
            is_exclusion_zone="false"/>
          <PublishHighLevelStatus state="1" state_name="RECORDING_COMPLETE"/>
          <ClearCommand/>
        </Sequence>

        <!-- ============================================================
             e. Manual Mowing (COMMAND_MANUAL_MOW = 7)
             Teleop via /cmd_vel_teleop (twist_mux priority).
             Collision_monitor remains active. GPS/SLAM continues.

             Blade is enabled here by the BT (not the GUI) because the
             firmware forcibly zeroes target_blade_on_off whenever its
             mirrored HL mode is IDLE/NULL (cpp_main.cpp on_hl_state).
             The GUI used to send mow_enabled=1 immediately after
             Command=7, but the firmware had not yet received the
             MANUAL_MOWING mode update, so it zeroed the blade. Driving
             the blade on AFTER PublishHighLevelStatus(4) guarantees the
             firmware sees MANUAL_MOWING first, then the blade command.

             ReactiveSequence is used deliberately: on every tick it
             re-evaluates IsCommand from the first child, even while
             WaitForDuration is running. When the user presses Home
             (command changes from 7 to 2), IsCommand returns FAILURE,
             the ReactiveSequence halts WaitForDuration and returns
             FAILURE, allowing the Fallback to select HomeSequence on
             the very next tick. On exit, the following sequence (Home
             or Idle) calls SetMowerEnabled(false) which stops the blade.
             ============================================================ -->
        <ReactiveSequence name="ManualMowingSequence">
          <IsCommand command="7"/>
          <PublishHighLevelStatus state="4" state_name="MANUAL_MOWING"/>
          <SetMowerEnabled enabled="true"/>
          <WaitForDuration duration_sec="0.5"/>
        </ReactiveSequence>

        <!-- ============================================================
             f. Idle default
             ============================================================ -->
        <Sequence name="IdleSequence">
          <SetMowerEnabled enabled="false"/>
          <StopMoving/>
          <PublishHighLevelStatus state="1" state_name="IDLE"/>
          <WaitForDuration duration_sec="0.5"/>
        </Sequence>

      </Fallback>
    </ReactiveSequence>
  </BehaviorTree>

</root>
