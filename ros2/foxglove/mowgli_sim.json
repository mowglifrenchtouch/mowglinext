{
  "configById": {
    "3D!main": {
      "followTf": "base_link",
      "scene": {
        "labelScaleFactor": 1,
        "enableStats": false,
        "backgroundColor": "#1a1a2e",
        "transforms": {
          "axisScale": 0.3,
          "lineWidth": 0.01,
          "editable": false,
          "enablePreloading": false
        }
      },
      "cameraState": {
        "distance": 12,
        "perspective": true,
        "phi": 55,
        "target": [0, 0, 0],
        "targetOffset": [0, 0, 0],
        "targetOrientation": [0, 0, 0, 1],
        "thetaOffset": 45,
        "fovy": 45,
        "near": 0.01,
        "far": 500
      },
      "topics": {
        "/scan": {
          "visible": true,
          "pointSize": 3,
          "colorMode": "flat",
          "flatColor": "#ff3333",
          "decayTime": 0
        },
        "/map": {
          "visible": true,
          "alpha": 0.5,
          "unknownColor": "#1a1a2e"
        },
        "/map_server_node/coverage_cells": {
          "visible": true,
          "alpha": 0.7,
          "unknownColor": "#00000000",
          "minColor": "#22cc44",
          "maxColor": "#cc2222"
        },
        "/map_server_node/mow_progress": {
          "visible": false,
          "alpha": 0.5,
          "unknownColor": "#00000000"
        },
        "/local_costmap/costmap": {
          "visible": false,
          "alpha": 0.3
        },
        "/global_costmap/costmap": {
          "visible": false,
          "alpha": 0.3
        },
        "/robot_description": {
          "visible": true
        },
        "/plan": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.03,
          "color": "#ffaa00"
        },
        "/local_plan": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.04,
          "color": "#00aaff"
        },
        "/keepout_mask": {
          "visible": true,
          "alpha": 0.4,
          "unknownColor": "#00000000"
        },
        "/speed_mask": {
          "visible": false,
          "alpha": 0.3,
          "unknownColor": "#00000000"
        },
        "/obstacle_tracker/markers": {
          "visible": true
        },
        "/FollowCoveragePath/global_plan": {
          "visible": true,
          "type": "line",
          "lineWidth": 0.02,
          "color": "#44ff44"
        },
        "/FollowCoveragePath/global_point": {
          "visible": true
        },
        "/wheel_odom": {
          "visible": false
        }
      },
      "publish": {
        "type": "pose_estimate",
        "poseTopic": "/initialpose",
        "pointTopic": "/clicked_point",
        "poseEstimateThetaDeviation": 0.26179939
      }
    },
    "CallService!start_mowing": {
      "serviceName": "/behavior_tree_node/high_level_control",
      "requestPayload": "{ \"command\": 1 }"
    },
    "CallService!return_home": {
      "serviceName": "/behavior_tree_node/high_level_control",
      "requestPayload": "{ \"command\": 2 }"
    },
    "CallService!stop": {
      "serviceName": "/behavior_tree_node/high_level_control",
      "requestPayload": "{ \"command\": 254 }"
    },
    "Publish!teleop": {
      "topicName": "/cmd_vel_teleop",
      "datatype": "geometry_msgs/msg/Twist",
      "value": "{ \"linear\": { \"x\": 0.0, \"y\": 0.0, \"z\": 0.0 }, \"angular\": { \"x\": 0.0, \"y\": 0.0, \"z\": 0.0 } }"
    },
    "RawMessages!status": {
      "topicPath": "/behavior_tree_node/high_level_status",
      "diffEnabled": false,
      "diffMethod": "custom",
      "diffTopicPath": "",
      "showFullMessageForDiff": false
    },
    "Plot!velocity": {
      "paths": [
        {
          "value": "/cmd_vel.linear.x",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "cmd_vel linear.x",
          "color": "#e74c3c",
          "showLine": true
        },
        {
          "value": "/cmd_vel.angular.z",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "cmd_vel angular.z",
          "color": "#3498db",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "Velocity Commands"
    },
    "Plot!battery": {
      "paths": [
        {
          "value": "/hardware_bridge/power.v_battery",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Battery (V)",
          "color": "#4e98e2",
          "showLine": true
        },
        {
          "value": "/hardware_bridge/power.v_charge",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Charger (V)",
          "color": "#2ecc71",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "Power"
    },
    "StateTransitions!bt": {
      "paths": [
        {
          "value": "/behavior_tree_node/high_level_status.state_name",
          "label": "BT State",
          "timestampMethod": "receiveTime"
        }
      ]
    },
    "Log!rosout": {
      "searchTerms": [],
      "minLogLevel": 2,
      "nameFilter": {}
    },
    "Indicator!state": {
      "path": "/behavior_tree_node/high_level_status.state_name",
      "style": "background",
      "fallbackColor": "#555555",
      "fallbackLabel": "UNKNOWN",
      "rules": [
        {
          "operator": "=",
          "rawValue": "IDLE",
          "color": "#3498db",
          "label": "IDLE"
        },
        {
          "operator": "=",
          "rawValue": "IDLE_DOCKED",
          "color": "#3498db",
          "label": "DOCKED"
        },
        {
          "operator": "=",
          "rawValue": "MOWING",
          "color": "#2ecc71",
          "label": "MOWING"
        },
        {
          "operator": "=",
          "rawValue": "TRANSIT",
          "color": "#f39c12",
          "label": "TRANSIT"
        },
        {
          "operator": "=",
          "rawValue": "UNDOCKING",
          "color": "#f39c12",
          "label": "UNDOCKING"
        },
        {
          "operator": "=",
          "rawValue": "RECOVERING",
          "color": "#e67e22",
          "label": "RECOVERING"
        },
        {
          "operator": "=",
          "rawValue": "PLANNING",
          "color": "#9b59b6",
          "label": "PLANNING"
        },
        {
          "operator": "=",
          "rawValue": "COVERAGE_FAILED_DOCKING",
          "color": "#e74c3c",
          "label": "FAILED"
        }
      ]
    },
    "Indicator!emergency": {
      "path": "/behavior_tree_node/high_level_status.emergency",
      "style": "background",
      "fallbackColor": "#2ecc71",
      "fallbackLabel": "OK",
      "rules": [
        {
          "operator": "=",
          "rawValue": "true",
          "color": "#e74c3c",
          "label": "EMERGENCY"
        }
      ]
    },
    "Gauge!coverage": {
      "path": "/behavior_tree_node/high_level_status.battery_percent",
      "minValue": 0,
      "maxValue": 100,
      "colorMode": "gradient",
      "gradient": ["#e74c3c", "#f39c12", "#2ecc71"],
      "reverse": false
    },
    "RawMessages!diagnostics": {
      "topicPath": "/diagnostics",
      "diffEnabled": false,
      "diffMethod": "custom",
      "diffTopicPath": "",
      "showFullMessageForDiff": false
    },
    "Plot!gps_precision": {
      "paths": [
        {
          "value": "/gps/fix.position_covariance[0]",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "GPS Covariance X",
          "color": "#e74c3c",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "GPS Precision",
      "yAxisMin": 0
    },
    "Plot!wheel_odom": {
      "paths": [
        {
          "value": "/wheel_odom.twist.twist.linear.x",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Wheel Speed (m/s)",
          "color": "#2ecc71",
          "showLine": true
        },
        {
          "value": "/cmd_vel.linear.x",
          "enabled": true,
          "timestampMethod": "receiveTime",
          "label": "Cmd Vel (m/s)",
          "color": "#3498db",
          "showLine": true
        }
      ],
      "showXAxisLabels": true,
      "showYAxisLabels": true,
      "showLegend": true,
      "legendDisplay": "floating",
      "showPlotValuesInLegend": true,
      "isSynced": true,
      "xAxisVal": "timestamp",
      "title": "Wheel Odometry vs Commanded",
      "yAxisMin": -0.1
    }
  },
  "globalVariables": {},
  "layout": {
    "first": {
      "first": "3D!main",
      "second": {
        "first": {
          "first": {
            "first": "Indicator!state",
            "second": "Indicator!emergency",
            "direction": "row",
            "splitPercentage": 60
          },
          "second": {
            "first": "CallService!start_mowing",
            "second": {
              "first": "CallService!return_home",
              "second": "CallService!stop",
              "direction": "column",
              "splitPercentage": 50
            },
            "direction": "column",
            "splitPercentage": 33
          },
          "direction": "column",
          "splitPercentage": 15
        },
        "second": {
          "first": "Publish!teleop",
          "second": {
            "first": "RawMessages!status",
            "second": "StateTransitions!bt",
            "direction": "column",
            "splitPercentage": 50
          },
          "direction": "column",
          "splitPercentage": 30
        },
        "direction": "column",
        "splitPercentage": 45
      },
      "direction": "row",
      "splitPercentage": 75
    },
    "second": {
      "first": {
        "first": "Plot!velocity",
        "second": "Plot!battery",
        "direction": "row",
        "splitPercentage": 50
      },
      "second": {
        "first": {
          "first": "Plot!gps_precision",
          "second": "Plot!wheel_odom",
          "direction": "row",
          "splitPercentage": 50
        },
        "second": {
          "first": "Log!rosout",
          "second": "RawMessages!diagnostics",
          "direction": "row",
          "splitPercentage": 60
        },
        "direction": "column",
        "splitPercentage": 50
      },
      "direction": "column",
      "splitPercentage": 40
    },
    "direction": "column",
    "splitPercentage": 60
  },
  "playbackConfig": {
    "speed": 1
  },
  "userNodes": {},
  "version": 1
}
