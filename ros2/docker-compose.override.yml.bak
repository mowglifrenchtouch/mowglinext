# =============================================================================
# docker-compose.override.yml — Development overrides
#
# Docker Compose automatically merges this file on top of docker-compose.yml
# when you run `docker compose up` (no -f flag needed).
#
# Activates:
#   - Live source bind-mount for mowgli and nav services
#   - DEBUG log level across all services
#   - Faster restart policy for tighter dev feedback loop
# =============================================================================
version: "3.9"

services:

  # Override the main robot service to mount source live and enable debug logs
  mowgli:
    environment:
      RCUTILS_LOGGING_SEVERITY_THRESHOLD: DEBUG
      RCUTILS_LOGGING_USE_STDOUT: "1"
      # Verbose colcon / launch output
      LAUNCH_LOGGING_CONFIG: "console"
    volumes:
      # Bind-mount launch and config directories so you can edit them without
      # rebuilding the image. The compiled install/ is still from the image.
      - ./src/mowgli_bringup/launch:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/launch:ro
      - ./src/mowgli_bringup/config:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/config:ro
      - ./src/mowgli_localization/launch:/ros2_ws/install/mowgli_localization/share/mowgli_localization/launch:ro
      - ./src/mowgli_localization/config:/ros2_ws/install/mowgli_localization/share/mowgli_localization/config:ro
      - mowgli_maps:/ros2_ws/maps
    restart: "no"

  simulation:
    environment:
      RCUTILS_LOGGING_SEVERITY_THRESHOLD: DEBUG
      RCUTILS_LOGGING_USE_STDOUT: "1"
    volumes:
      - ./src/mowgli_bringup/launch:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/launch:ro
      - ./src/mowgli_bringup/config:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/config:ro
      - mowgli_maps:/ros2_ws/maps
    restart: "no"

  nav:
    environment:
      RCUTILS_LOGGING_SEVERITY_THRESHOLD: DEBUG
      RCUTILS_LOGGING_USE_STDOUT: "1"
    volumes:
      - ./src/mowgli_bringup/launch:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/launch:ro
      - ./src/mowgli_bringup/config:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/config:ro
      - mowgli_maps:/ros2_ws/maps
    restart: "no"

  dev-sim:
    environment:
      RCUTILS_LOGGING_SEVERITY_THRESHOLD: DEBUG
      RCUTILS_LOGGING_USE_STDOUT: "1"
    volumes:
      - ./src/mowgli_bringup/launch:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/launch:ro
      - ./src/mowgli_bringup/config:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/config:ro
      - ./src/mowgli_behavior/trees:/ros2_ws/install/mowgli_behavior/share/mowgli_behavior/trees:ro
    restart: "no"

  dev-sim-small:
    environment:
      RCUTILS_LOGGING_SEVERITY_THRESHOLD: DEBUG
      RCUTILS_LOGGING_USE_STDOUT: "1"
    volumes:
      - ./src/mowgli_bringup/launch:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/launch:ro
      - ./src/mowgli_bringup/config:/ros2_ws/install/mowgli_bringup/share/mowgli_bringup/config:ro
      - ./src/mowgli_behavior/trees:/ros2_ws/install/mowgli_behavior/share/mowgli_behavior/trees:ro
      - ./src/mowgli_behavior/config:/ros2_ws/install/mowgli_behavior/share/mowgli_behavior/config:ro
    restart: "no"

  dev:
    environment:
      RCUTILS_LOGGING_SEVERITY_THRESHOLD: DEBUG
    restart: "no"
